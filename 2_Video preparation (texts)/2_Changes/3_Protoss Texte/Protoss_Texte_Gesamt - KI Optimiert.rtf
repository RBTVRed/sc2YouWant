\par \pard\plain \s0\rtlch\af11\afs24\alang1081 \ltrch\lang1031\langfe2052\hich\af3\loch\ql\nowidctlpar\hyphpar0\ltrpar\cf0\f3\fs24\lang1031\kerning1\dbch\af8\langfe2052\fi0\li0\lin0\ri0\rin0{\hich\af6\loch\cs17\rtlch\af12 \ltrch\hich\af4\loch\f4\dbch\af7\f6\dbch\af10\loch
160_Void Ray}
\par \pard\plain \s0\rtlch\af11\afs24\alang1081 \ltrch\lang1031\langfe2052\hich\af3\loch\ql\nowidctlpar\hyphpar0\ltrpar\cf0\f3\fs24\lang1031\kerning1\dbch\af8\langfe2052\fi0\li0\lin0\ri0\rin0{\hich\af6\loch\cs17\rtlch\af12 \ltrch\hich\af4\loch\f4\dbch\af7\f6\dbch\af10
\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f\u9552\'3f}
\par \pard\plain \s0\rtlch\af11\afs24\alang1081 \ltrch\lang1031\langfe2052\hich\af3\loch\ql\nowidctlpar\hyphpar0\ltrpar\cf0\f3\fs24\lang1031\kerning1\dbch\af8\langfe2052\fi0\li0\lin0\ri0\rin0{\hich\af6\loch\cs17\rtlch\af12 \ltrch\hich\af4\loch\f4\dbch\af7\f6\dbch\af10
