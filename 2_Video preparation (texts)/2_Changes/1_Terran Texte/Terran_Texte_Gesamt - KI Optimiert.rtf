\par \pard\plain \s0\rtlch\af10\afs24\alang1081 \ltrch\lang1031\langfe2052\hich\af3\loch\ql\nowidctlpar\hyphpar0\ltrpar\cf0\f3\fs24\lang1031\kerning1\dbch\af8\langfe2052\fi0\li0\lin0\ri0\rin0{\loch\cs17\rtlch\af11 \ltrch\hich\af4\loch\f4\dbch\af7\dbch\af9\loch
